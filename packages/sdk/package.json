{
	"name": "@rifted/sdk",
	"version": "0.1.0",
	"description": "Typed builders for Rifted game content files",
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./schema": {
			"types": "./dist/schema/index.d.ts",
			"import": "./dist/schema/index.js"
		}
	},
	"files": ["dist", "README.md"],
	"scripts": {
		"build": "bun run build:types && bun run build:schema",
		"build:types": "tsc --emitDeclarationOnly --outDir dist",
		"build:schema": "bun run scripts/emit-json-schema.ts",
		"typecheck": "tsc --noEmit",
		"test": "bun test"
	},
	"dependencies": {
		"zod": "^4.0.0"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"typescript": "^5.7.0"
	},
	"engines": {
		"node": ">=20"
	},
	"keywords": ["rifted", "gamedev", "modding", "sdk"],
	"license": "MIT"
}
