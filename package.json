{
	"name": "rifted-sdk-monorepo",
	"private": true,
	"type": "module",
	"workspaces": ["packages/*"],
	"scripts": {
		"build": "bun run --filter '*' build",
		"test": "bun test",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"typecheck": "bun run --filter '*' typecheck",
		"prepare": "lefthook install"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.0.0",
		"@changesets/cli": "^2.27.0",
		"@types/bun": "latest",
		"lefthook": "^1.10.0",
		"lint-staged": "^15.2.0",
		"typescript": "^5.7.0"
	},
	"engines": {
		"node": ">=20"
	},
	"packageManager": "bun@1.3.12"
}
