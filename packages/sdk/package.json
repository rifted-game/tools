{
	"name": "@rifted/sdk",
	"version": "0.0.7",
	"description": "Typed builders for Rifted game content files",
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/rifted-game/tools.git",
		"directory": "packages/sdk"
	},
	"homepage": "https://github.com/rifted-game/tools/tree/main/packages/sdk#readme",
	"bugs": {
		"url": "https://github.com/rifted-game/tools/issues"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./schema": {
			"types": "./dist/schema/index.d.ts",
			"import": "./dist/schema/index.js"
		},
		"./pack": {
			"types": "./dist/pack/index.d.ts",
			"import": "./dist/pack/index.js"
		},
		"./locales": {
			"types": "./dist/locales/index.d.ts",
			"import": "./dist/locales/index.js"
		},
		"./raw": {
			"types": "./dist/raw.d.ts",
			"import": "./dist/raw.js"
		}
	},
	"files": [
		"dist",
		"tsconfig.mod.json",
		"README.md"
	],
	"scripts": {
		"build": "bun run build:js && bun run build:types && bun run build:schema && bun run build:context",
		"build:js": "bun build ./src/index.ts ./src/raw.ts ./src/schema/index.ts ./src/pack/index.ts ./src/locales/index.ts --outdir ./dist --target node --format esm --external @fluent/syntax --external jszip --external zod",
		"build:types": "tsc --emitDeclarationOnly --outDir dist",
		"build:schema": "bun run scripts/emit-json-schema.ts",
		"build:dts-bundle": "dts-bundle-generator --config dts-bundle-generator.config.json",
		"build:context": "bun run scripts/emit-context.ts",
		"typecheck": "tsc --noEmit",
		"test": "bun test"
	},
	"dependencies": {
		"@fluent/syntax": "^0.19.0",
		"jszip": "^3.10.1",
		"zod": "^4.0.0"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"dts-bundle-generator": "^9.5.1",
		"typescript": "^5.7.0"
	},
	"engines": {
		"node": ">=20"
	},
	"keywords": [
		"rifted",
		"gamedev",
		"modding",
		"sdk"
	],
	"license": "MIT"
}
