{
	"name": "@rifted/cli",
	"version": "1.1.1",
	"description": "Command-line tools for building Rifted mods",
	"type": "module",
	"bin": {
		"rifted": "dist/cli.js"
	},
	"main": "./dist/cli.js",
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/rifted-game/tools.git",
		"directory": "packages/cli"
	},
	"homepage": "https://github.com/rifted-game/tools/tree/main/packages/cli#readme",
	"bugs": {
		"url": "https://github.com/rifted-game/tools/issues"
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"build": "bun build src/cli.ts --outdir dist --target node --format esm --external @rifted/sdk --external jszip --external zod --external @fluent/syntax --external citty --external picocolors --external jiti --external @clack/prompts",
		"typecheck": "tsc --noEmit -p tsconfig.typecheck.json"
	},
	"dependencies": {
		"@clack/prompts": "^0.10.0",
		"@rifted/sdk": "workspace:*",
		"citty": "^0.1.6",
		"jiti": "^2.7.0",
		"picocolors": "^1.1.1",
		"zod": "^4.0.0"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"typescript": "^5.7.0"
	},
	"engines": {
		"node": ">=20"
	},
	"keywords": [
		"rifted",
		"gamedev",
		"modding",
		"cli"
	],
	"license": "MIT"
}
